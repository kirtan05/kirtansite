---
interface Props {
  href?: string;
  class?: string;
  span?: 'full' | 'half';
}

const { href, class: className = '', span } = Astro.props;

const Tag = href ? 'a' : 'div';

const spanClass = span === 'full' ? 'md:col-span-2' : span === 'half' ? 'md:col-span-1' : '';

const baseClasses = [
  'relative overflow-hidden rounded-2xl border border-accent/12 bg-surface/80 p-6 backdrop-blur-xl',
  'transition-all duration-300',
  'hover:border-accent/25 hover:shadow-[0_0_40px_-5px_rgba(245,158,11,0.15)]',
  spanClass,
  className,
].filter(Boolean).join(' ');
---

<Tag
  href={href}
  class={baseClasses}
  data-animate
  data-tilt
>
  <slot />
</Tag>
