---
// Hero section with name character stagger and cycling tagline
const name = "Kirtan Jain";
const chars = Array.from(name);
---

<div class="flex h-full flex-col justify-center">
  <h1 class="hero-name font-display text-4xl font-bold leading-tight text-text sm:text-5xl md:text-7xl">
    {chars.map((char) => (
      <span class="hero-char inline-block">
        {char === ' ' ? '\u00A0' : char}
      </span>
    ))}
  </h1>
  <p class="hero-tagline mt-4 text-lg text-text-secondary md:text-xl">
    <span
      class="tagline-word text-text"
      data-words='["builder", "engineer", "researcher"]'
    >builder</span><span class="text-accent">.</span>
  </p>
</div>
