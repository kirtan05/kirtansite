---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<div
  class="rounded-2xl border border-border/50 bg-surface/80 p-6 backdrop-blur-xl hover:border-accent/20 hover:shadow-[0_0_30px_-5px_rgba(245,158,11,0.1)] transition-all duration-300"
  style="border-top: 0.5px solid rgba(255,255,255,0.05);"
  data-scroll-animate
  data-tilt
>
  <span class="text-xs font-mono uppercase tracking-widest text-accent">Project</span>

  <h2 class="mt-2 font-display text-2xl font-bold text-text">{project.title}</h2>

  <p class="mt-3 leading-relaxed text-text-secondary">
    {project.longDescription ?? project.description}
  </p>

  {project.tech.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-2">
      {project.tech.map((t) => (
        <span class="rounded-md bg-border/80 px-2 py-1 font-mono text-xs text-text-secondary">
          {t}
        </span>
      ))}
    </div>
  )}

  {project.links.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-4">
      {project.links.map((link) => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 font-mono text-sm text-accent hover:text-accent-hover transition-colors duration-200"
        >
          {link.label}
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M7 17L17 7" />
            <path d="M7 7h10v10" />
          </svg>
        </a>
      ))}
    </div>
  )}
</div>
