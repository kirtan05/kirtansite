---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects';
---

<BaseLayout title="Projects — Kirtan Jain">
  <section class="mx-auto max-w-4xl px-6 py-12 md:py-20">
    <div data-scroll-animate>
      <h1 class="font-display text-4xl font-bold md:text-5xl">Projects</h1>
      <p class="mt-3 text-lg text-text-secondary">Things I've built and shipped.</p>
    </div>

    <div class="mt-10 space-y-6">
      {projects.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>
  </section>
</BaseLayout>
