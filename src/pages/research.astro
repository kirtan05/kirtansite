---
import BaseLayout from '../layouts/BaseLayout.astro';
import PaperCard from '../components/PaperCard.astro';
import { papers } from '../data/papers';
---

<BaseLayout title="Research — Kirtan Jain">
  <section class="mx-auto max-w-4xl px-6 py-12 md:py-20">
    <div data-scroll-animate>
      <h1 class="font-display text-4xl font-bold md:text-5xl">Research</h1>
      <p class="mt-3 text-lg text-text-secondary">
        Published work in multimodal machine learning, video understanding, and NLP.
      </p>
    </div>

    <div class="mt-10 space-y-6">
      {papers.map((paper) => (
        <PaperCard paper={paper} />
      ))}
    </div>
  </section>
</BaseLayout>
